# Copy to .env for local runs. In production these are set as GitHub Actions secrets/vars.
# pydantic-settings matches these names to settings fields case-insensitively.

# --- Airtable (required) ---
AIRTABLE_API_TOKEN=pat_xxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# Table names — only change if you renamed them in Airtable.
EVENTS_TABLE=Events
RSVPS_TABLE=RSVPs
REMINDER_LOG_TABLE=ReminderLog

# --- Email via Resend (required for email reminders) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=canvass@jacksandor.ca
EMAIL_FROM_NAME=Jack Sandor Campaign
# Optional: replies go here instead of the from address.
EMAIL_REPLY_TO=volunteer@jacksandor.ca

# --- SMS via Twilio (optional — leave blank until the number is verified) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- New-RSVP alerts to the organizer (optional; needs Twilio configured above) ---
# When someone RSVPs "Going", text this number once. E.164, e.g. +12505550123.
# Leave blank to disable. Requires a "Created" field on the RSVPs table (see README).
JACK_PHONE=
# Only RSVPs created within this window count as "new" (m/h/d). Guards the first run
# from texting your whole existing RSVP list. Default 24h if blank.
NEW_RSVP_LOOKBACK=24h

# --- Behaviour ---
# Comma-separated lead times before each event. Supports m/h/d (e.g. 24h,2h,30m).
DEFAULT_REMINDER_OFFSETS=24h,2h
TIMEZONE=America/Vancouver
CAMPAIGN_NAME=Jack Sandor for Victoria
# Shown in the email/SMS opt-out line.
CAMPAIGN_CONTACT=the Jack Sandor campaign team
# SMS is only sent during these local hours (CRTC-friendly); outside the window it waits.
SMS_QUIET_START_HOUR=9
SMS_QUIET_END_HOUR=21
